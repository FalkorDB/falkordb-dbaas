{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SOC 2 Compliance Overview — Prowler scan results, Wazuh agent health, FIM status, and vulnerability summary.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Prowler CronJob Health",
      "description": "Last successful Prowler scan age — green means scan ran within 24h",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "orange", "value": 172800 },
              { "color": "red", "value": 259200 }
            ]
          },
          "unit": "s",
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "time() - max(kube_cronjob_status_last_successful_time{cronjob=\"prowler-soc2-scan\"})",
          "legendFormat": "Since last success"
        }
      ]
    },
    {
      "title": "Prowler Job Failures",
      "description": "Count of failed Prowler CronJob runs",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (namespace) (kube_job_status_failed{job_name=~\"prowler-soc2-scan-.*\"})",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "title": "Wazuh Agent Pods Desired",
      "description": "Number of Wazuh agent pods scheduled by the DaemonSet",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kube_daemonset_status_desired_number_scheduled{daemonset=\"wazuh-agent\"})",
          "legendFormat": "Desired"
        }
      ]
    },
    {
      "title": "Wazuh Agent Pods Unavailable",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kube_daemonset_status_number_unavailable{daemonset=\"wazuh-agent\"})",
          "legendFormat": "Unavailable"
        }
      ]
    },
    {
      "title": "ThreatMapper Sensors Unavailable",
      "description": "Unavailable ThreatMapper sensor pods across clusters",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kube_daemonset_status_number_unavailable{daemonset=\"threatmapper-sensor\"})",
          "legendFormat": "Unavailable Sensors"
        }
      ]
    },
    {
      "title": "Wazuh Manager Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=\"wazuh-manager\"}",
          "legendFormat": "Manager"
        }
      ]
    },
    {
      "title": "Security CronJob Timeline",
      "description": "Prowler CronJob success/failure timeline over the last 30 days",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "pointSize": 5
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kube_job_status_succeeded{job_name=~\"prowler-soc2-scan-.*\"})",
          "legendFormat": "Succeeded"
        },
        {
          "expr": "sum(kube_job_status_failed{job_name=~\"prowler-soc2-scan-.*\"})",
          "legendFormat": "Failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "DaemonSet Health Overview",
      "description": "Security DaemonSet availability across the fleet",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_daemonset_status_number_ready{daemonset=~\"wazuh-agent|threatmapper-sensor\"})",
          "legendFormat": "Ready"
        },
        {
          "expr": "sum(kube_daemonset_status_number_unavailable{daemonset=~\"wazuh-agent|threatmapper-sensor\"})",
          "legendFormat": "Unavailable"
        }
      ]
    },
    {
      "title": "Security Namespace Pod Status",
      "description": "Pod status in the security namespace",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "kube_pod_status_phase{namespace=\"security\"}",
          "legendFormat": "{{ pod }}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "pod": "Pod",
              "phase": "Phase",
              "Value": "Count"
            }
          }
        }
      ]
    },
    {
      "title": "Prowler CronJob Last Schedule",
      "description": "Time since the Prowler CronJob was last scheduled, by cluster",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "red", "value": 172800 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "time() - kube_cronjob_status_last_schedule_time{cronjob=\"prowler-soc2-scan\"}",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["soc2", "compliance", "security", "prowler", "wazuh", "threatmapper"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "VictoriaMetrics", "value": "VictoriaMetrics" },
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "SOC 2 Compliance Overview",
  "uid": "soc2-compliance-overview",
  "version": 1
}
